# ─────────────────────────────────────────────────────────────────────────────
# CallMind — Environment Variables Template
# Copy this file to .env and fill in your own keys.
# DO NOT commit your real .env file to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic / Claude (AI Brain) ────────────────────────────────────────────
# Sign up at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Deepgram (Speech-to-Text) ────────────────────────────────────────────────
# Sign up at https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=

# ── ElevenLabs (Text-to-Speech) ──────────────────────────────────────────────
# Sign up at https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
# Find voice IDs at https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=

# ── Exotel (Telephony) ───────────────────────────────────────────────────────
# Sign up at https://my.exotel.com → Settings → API
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_CALLER_ID=
EXOTEL_SUBDOMAIN=api.exotel.com

# ── WhatsApp Notifications (leave blank to disable) ──────────────────────────
WHATSAPP_PROVIDER=url
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_TO_NUMBER=

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL dev (SQLite — default, no setup needed):
# DATABASE_URL=sqlite+aiosqlite:///./aria.db
#
# PRODUCTION (PostgreSQL — Render auto-injects this online, but put your Render DB URL here to migrate local data):
DATABASE_URL=

# ── App Config ────────────────────────────────────────────────────────────────
# Your public backend URL (e.g. ngrok tunnel or deployed URL)
BASE_URL=https://your-ngrok-or-deployed-url.com
ARIA_OWNER_NAME=YourName
ARIA_ENABLED=true

# ── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of phone numbers allowed to trigger outbound calls
WHITELISTED_NUMBERS=
